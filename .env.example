# --- Contact / custom-order form delivery ------------------------------
# The site is a static export (for GitHub Pages), so forms are sent via
# Web3Forms (https://web3forms.com) — a free service that emails you the
# submission. No backend, no domain verification needed.
#
# 1. Go to https://web3forms.com, enter Nicky's email, and get an Access Key.
# 2. For LOCAL dev: copy this file to ".env.local" and paste the key below.
# 3. For PRODUCTION (GitHub Pages): add the key as a repository secret named
#    WEB3FORMS_KEY (Settings → Secrets and variables → Actions). The deploy
#    workflow passes it in as NEXT_PUBLIC_WEB3FORMS_KEY at build time.
#
# Note: this key is public by design (it ships in the built site). That's how
# Web3Forms works — the key only allows sending to Nicky's verified inbox.
NEXT_PUBLIC_WEB3FORMS_KEY=

# --- Hosting base path -------------------------------------------------
# Only needed if you build/preview the production export locally. The GitHub
# Actions workflow sets this automatically to "/<repo-name>". Leave blank for
# local "npm run dev".
# NEXT_PUBLIC_BASE_PATH=/Nicky_B
